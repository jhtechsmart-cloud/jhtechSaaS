{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/worker/**",
      "packages/shared/**",
      "pnpm-lock.yaml",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter worker start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
