# jhtechSaaS 환경변수 예시 — 실제 값은 .env.local(web) / .env(worker)에 넣고 절대 커밋 금지
# Zod 스키마: apps/web/src/env.ts, apps/worker/src/env.ts

# === Supabase: web 클라이언트 노출 OK (빌드 시 인라인) ===
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# === Supabase: 서버 전용 (절대 클라이언트 노출 금지) ===
# web 서버 액션 + worker 에서 사용. RLS 우회 권한이므로 서버 파일에서만.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# === Supabase: worker 용 URL (NEXT_PUBLIC_ 접두사 없이) ===
SUPABASE_URL=https://<project-ref>.supabase.co

# === 메일 발송 (worker, Gmail SMTP) ===
GMAIL_USER=jhtechsmart@gmail.com
GMAIL_APP_PASSWORD=<google-app-password>
